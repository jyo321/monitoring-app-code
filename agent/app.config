# PalTech MonitoringHub — Agent Configuration
# Place this file in the same directory as disk-monitor.sh on each monitored server.
# Both files should live together, e.g. /opt/monitoring/
#
# After editing, test with:
#   /opt/monitoring/disk-monitor.sh

# ── Required ──────────────────────────────────────────────────────────────────

# Full base URL of the MonitoringHub backend (no trailing slash).
# Replace with your actual backend IP or Cloudflare tunnel URL.
# Examples:
#   API_URL=http://10.212.135.14:5000
#   API_URL=https://abc-xyz.trycloudflare.com
API_URL=http://YOUR_BACKEND_IP:5000

# Bearer token — must match ApiToken in backend appsettings.json
API_TOKEN=monitor-secret-token-2024

# ── Optional ──────────────────────────────────────────────────────────────────

# Log file path on the monitored server
LOG_FILE=/var/log/disk-monitor.log

# Number of retry attempts on failure before giving up
MAX_RETRIES=3
